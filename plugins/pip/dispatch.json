{
  "entries": [
    { "target": "<name>", "verb": "add",    "handler": "install" },
    { "target": "<name>", "verb": "remove", "handler": "uninstall" },
    { "target": "<name>", "verb": "set",    "handler": "pin_version" },
    { "target": "all",    "verb": "set",    "handler": "upgrade_all" }
  ],
  "policy": {
    "install":     "medium",
    "uninstall":   "high",
    "pin_version": "medium",
    "upgrade_all": "high"
  }
}
