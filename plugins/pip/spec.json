{
  "domain": "pip",
  "observations": {
    "packages": {
      "type": "array",
      "item": {
        "name": "string",
        "version": "string",
        "latest_version": "string | null",
        "outdated": "bool"
      }
    },
    "python_version": "string",
    "pip_version": "string",
    "virtualenv": "string | null",
    "installed": "bool",
    "version": "string | null"
  },
  "actions": [
    { "target": "<name>", "verbs": ["add"],    "description": "Install a pip package",            "mutates": ["pip.installed", "pip.version"], "resolves": "installed" },
    { "target": "<name>", "verbs": ["remove"], "description": "Uninstall a pip package",          "mutates": ["pip.installed"] },
    { "target": "<name>", "verbs": ["set"],    "description": "Pin to a version",                 "mutates": ["pip.version"], "args": { "version": { "type": "string" } } },
    { "target": "all",    "verbs": ["set"],    "description": "Upgrade all outdated packages",    "mutates": ["pip.installed", "pip.version"], "args": { "version": { "type": "string", "enum": ["latest"] } } }
  ]
}
